#!/usr/bin/env python3
import sys
import os
import json

# Read settings from launcher
settings = {
    "force_path": "jedi",
    "bundle_coding": False,
    "bundle_gaming": False,
    "bundle_media": False,
    "bleed_crystal": False,
    "optimize_mirrors": True
}

if os.path.exists("/tmp/kyber_settings.json"):
    try:
        with open("/tmp/kyber_settings.json", "r") as f:
            settings.update(json.load(f))
    except:
        pass

# Detect target root
target_root = ""
for d in os.listdir("/tmp"):
    if d.startswith("calamares-root-"):
        target_root = os.path.join("/tmp", d)
        break

if not target_root:
    print("Error: Could not find Calamares target root.")
    sys.exit(1)

print(f"Kyber OS Post-Installation Synchronization in {target_root}...")

# Mirror Optimization
if settings['optimize_mirrors']:
    print("Optimizing Holocron network uplinks...")
    os.system(f"arch-chroot {target_root} reflector --latest 20 --protocol https --sort rate --save /etc/pacman.d/mirrorlist")

# Execute postinstall
os.system(f"/usr/local/bin/kyber-postinstall --force-path {settings['force_path']} --target {target_root}")

# Install Bundles
if settings['bundle_coding']:
    os.system(f"arch-chroot {target_root} pacman -S gcc cmake dotnet-sdk docker github-cli discord neofetch --noconfirm")

if settings['bundle_gaming']:
    os.system(f"arch-chroot {target_root} pacman -S steam lutris gamemode --noconfirm")

if settings['bundle_media']:
    os.system(f"arch-chroot {target_root} pacman -S vlc gst-libav libreoffice-fresh --noconfirm")

# Bleed the Crystal
if settings['bleed_crystal']:
    os.system(f"/usr/local/bin/kyber-bleed-crystal --target {target_root}")

print("Synchronization Complete.")
