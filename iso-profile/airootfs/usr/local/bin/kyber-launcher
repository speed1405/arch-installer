#!/usr/bin/env python3
import sys
import os
import subprocess
import json
from PyQt5.QtWidgets import (QApplication, QWidget, QPushButton, QVBoxLayout,
                             QLabel, QHBoxLayout, QRadioButton, QCheckBox,
                             QGroupBox, QFrame)
from PyQt5.QtCore import Qt
from PyQt5.QtGui import QFont, QPalette, QColor

class KyberLauncher(QWidget):
    def __init__(self):
        super().__init__()
        self.settings = {
            "force_path": "jedi",
            "bundle_coding": False,
            "bundle_gaming": False,
            "bundle_media": False,
            "bleed_crystal": False,
            "optimize_mirrors": True
        }
        self.initUI()

    def initUI(self):
        self.setWindowTitle('Kyber OS Initialization Sector')
        self.setFixedSize(700, 650)
        self.setWindowFlags(Qt.FramelessWindowHint | Qt.WindowStaysOnTopHint)

        palette = self.palette()
        palette.setColor(QPalette.Window, QColor("#1A1B26"))
        palette.setColor(QPalette.WindowText, QColor("#f3dfb4"))
        self.setPalette(palette)
        self.setAutoFillBackground(True)

        layout = QVBoxLayout()

        title = QLabel("THE KYBER LINK")
        title.setAlignment(Qt.AlignCenter)
        title.setFont(QFont('Courier', 32, QFont.Bold))
        title.setStyleSheet("color: #00D4FF; margin-top: 10px;")
        layout.addWidget(title)

        # --- Side Selection ---
        side_group = QGroupBox("CHOOSE YOUR PATH")
        side_group.setStyleSheet("QGroupBox { color: #f3dfb4; border: 1px solid #7d812c; margin-top: 10px; }")
        side_layout = QHBoxLayout()

        self.radio_jedi = QRadioButton("The Light Side (Jedi)")
        self.radio_jedi.setChecked(True)
        self.radio_jedi.setStyleSheet("color: #00D4FF;")
        self.radio_sith = QRadioButton("The Dark Side (Sith)")
        self.radio_sith.setStyleSheet("color: #FF0000;")

        side_layout.addWidget(self.radio_jedi)
        side_layout.addWidget(self.radio_sith)
        side_group.setLayout(side_layout)
        layout.addWidget(side_group)

        # --- Bundles ---
        bundle_group = QGroupBox("KNOWLEDGE BUNDLES")
        bundle_group.setStyleSheet("QGroupBox { color: #f3dfb4; border: 1px solid #7d812c; margin-top: 10px; }")
        bundle_layout = QVBoxLayout()

        self.check_coding = QCheckBox("[Jedi Sentinel] Developer Suite")
        self.check_gaming = QCheckBox("[Podracing] Gaming Bundle")
        self.check_media = QCheckBox("[Archives] Media/Office")

        bundle_layout.addWidget(self.check_coding)
        bundle_layout.addWidget(self.check_gaming)
        bundle_layout.addWidget(self.check_media)
        bundle_group.setLayout(bundle_layout)
        layout.addWidget(bundle_group)

        # --- Kernel & Optimization ---
        kernel_group = QGroupBox("SYSTEM OPTIMIZATION")
        kernel_group.setStyleSheet("QGroupBox { color: #f3dfb4; border: 1px solid #7d812c; margin-top: 10px; }")
        kernel_layout = QVBoxLayout()
        self.check_bleed = QCheckBox("Bleed the Crystal (Custom Kernel Source Compilation)")
        self.check_mirrors = QCheckBox("Synchronize Mirrors (Optimize Network Uplinks)")
        self.check_mirrors.setChecked(True)
        kernel_layout.addWidget(self.check_bleed)
        kernel_layout.addWidget(self.check_mirrors)
        kernel_group.setLayout(kernel_layout)
        layout.addWidget(kernel_group)

        # --- Action Buttons ---
        btn_layout = QHBoxLayout()

        self.btn_calamares = QPushButton("Graphical Installer\n(Calamares)")
        self.btn_calamares.setFixedSize(300, 80)
        self.btn_calamares.setStyleSheet("""
            QPushButton { background-color: #00D4FF; color: #1A1B26; font-weight: bold; border-radius: 5px; }
            QPushButton:hover { background-color: #f3dfb4; }
        """)
        self.btn_calamares.clicked.connect(self.launch_calamares)

        self.btn_terminal = QPushButton("Terminal Installer\n(Kyber Link)")
        self.btn_terminal.setFixedSize(300, 80)
        self.btn_terminal.setStyleSheet("""
            QPushButton { background-color: #D65D0E; color: #1A1B26; font-weight: bold; border-radius: 5px; }
            QPushButton:hover { background-color: #f3dfb4; }
        """)
        self.btn_terminal.clicked.connect(self.launch_terminal)

        btn_layout.addWidget(self.btn_calamares)
        btn_layout.addWidget(self.btn_terminal)
        layout.addLayout(btn_layout)

        footer = QLabel("May the Source be with you.")
        footer.setAlignment(Qt.AlignCenter)
        footer.setStyleSheet("color: #7d812c; margin-top: 10px;")
        layout.addWidget(footer)

        self.setLayout(layout)

    def save_settings(self):
        self.settings["force_path"] = "jedi" if self.radio_jedi.isChecked() else "sith"
        self.settings["bundle_coding"] = self.check_coding.isChecked()
        self.settings["bundle_gaming"] = self.check_gaming.isChecked()
        self.settings["bundle_media"] = self.check_media.isChecked()
        self.settings["bleed_crystal"] = self.check_bleed.isChecked()
        self.settings["optimize_mirrors"] = self.check_mirrors.isChecked()

        with open("/tmp/kyber_settings.json", "w") as f:
            json.dump(self.settings, f)

    def launch_calamares(self):
        self.save_settings()
        subprocess.Popen(["sudo", "calamares"])
        QApplication.quit()

    def launch_terminal(self):
        self.save_settings()
        subprocess.Popen(["kitty", "sudo", "/root/install.sh"])
        QApplication.quit()

if __name__ == '__main__':
    app = QApplication(sys.argv)
    ex = KyberLauncher()
    ex.show()
    sys.exit(app.exec_())
